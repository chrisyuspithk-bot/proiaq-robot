# ============================================================
# Pro-IAQ Social Media Monitor — Environment Configuration
# ============================================================
# Copy to .env and fill in your values.

# --- LLM (OpenAI-compatible) ---
# Use OpenRouter, DeepSeek direct, or any OpenAI-compatible endpoint.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# --- Browser Use ---
# Engine: "playwright" (free, direct selectors) or "browser-use" (LLM-driven, adaptive)
BROWSER_ENGINE=playwright
# Leave empty for local Playwright; set for Browser Use Cloud.
BROWSER_USE_API_KEY=
# Set to "cloud" to use Browser Use Cloud, "local" for local Playwright (browser-use engine only).
BROWSER_USE_MODE=local
# Show browser window? (true=headed, false=headless)
BROWSER_HEADED=false

# --- Profiles ---
# Base directory for persistent browser profiles.
CHROME_PROFILE_DIR=./data/profiles

# --- Scheduler ---
# "hourly", "daily", or "once"
SCHEDULE_MODE=hourly
# Max posts to process per platform per run.
MAX_POSTS_PER_PLATFORM=3
# Post age limit in hours (for hourly runs).
POST_MAX_AGE_HOURS=48
# Post age limit in days (for daily runs).
POST_MAX_AGE_DAYS=7

# --- Mode ---
# Set to "true" to extract + generate replies but NOT post them.
DRY_RUN=false

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database ---
SQLITE_DB_PATH=./data/state.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
